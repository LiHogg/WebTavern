PROJECT_NAME=webtavern-platform

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0,nginx,0.0.0.0
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
DJANGO_DEBUG=true

# Database
POSTGRES_DB=webtavern
POSTGRES_USER=webtavern
POSTGRES_PASSWORD=webtavern
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Email
ENABLE_EMAIL_NOTIFICATIONS=true
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Local demo mode is sent to MailHog: http://localhost:8025
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
EMAIL_TIMEOUT_SECONDS=10

# For real SMTP, fill these values in .env, for example:
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=465
# EMAIL_USE_SSL=true
# EMAIL_USE_TLS=false
# EMAIL_HOST_USER=your-mail@yandex.ru
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=WebTavern <your-mail@yandex.ru>
DEFAULT_FROM_EMAIL=no-reply@webtavern.local
SERVER_EMAIL=no-reply@webtavern.local
EMAIL_SUBJECT_PREFIX=[WebTavern]

# If set, every outgoing notification email goes to this real mailbox.
# Useful for local/demo testing when demo users have @webtavern.local emails.
EMAIL_RECIPIENT_OVERRIDE=
EMAIL_ADD_OVERRIDE_NOTE=true

# Frontend
NEXT_PUBLIC_APP_NAME=WebTavern
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080/ws

# Payments
PAYMENT_PROVIDER=yookassa
YOOKASSA_SHOP_ID=test-shop-id
YOOKASSA_SECRET_KEY=test-secret-key
YOOKASSA_RETURN_URL=http://localhost:8080/account/payments

# Notifications
ENABLE_BROWSER_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
# console = demo SMS in backend logs and delivery journal; smsru/webhook = real provider mode.
SMS_PROVIDER=console
SMS_FROM=WebTavern
SMSRU_API_ID=
SMS_WEBHOOK_URL=
SMS_TIMEOUT_SECONDS=10
PUBLIC_SITE_URL=http://localhost:8080

# Real map provider for the venue map module: yandex, google, or local.
# Yandex/Google require a browser JavaScript API key. Without a key the site falls back to the built-in local map.
MAPS_PROVIDER=yandex
YANDEX_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=
